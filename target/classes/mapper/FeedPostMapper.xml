<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.niit.feed.mapper.FeedPostMapper">

    <!--
      findMissedPosts：补拉机制 — 找出"我"未收到推送的遗漏帖子
      SQL 要点（详见 docs 第 2.6 节提示卡 3）：
        1. JOIN user 表拿发帖人姓名（user_name 别名）
        2. IN <foreach> 列出"我"关注的非大V用户 ID（不用 *，只用 IN）
        3. AND p.created_at > #{since}：只查"我离线期间"发的帖子（since = 我上次活跃时间）
        4. AND NOT EXISTS (...)：排除"已经写入我 inbox 的帖子"——只返回没收到推送的
           NOT EXISTS 语义："不存在匹配的子查询记录"。
           等价于 LEFT JOIN feed_inbox i ON ... WHERE i.id IS NULL，但更简洁。
        5. ORDER BY p.created_at DESC LIMIT #{size}：按时间倒序取前 size 条
    -->
    <select id="findMissedPosts" resultType="com.niit.feed.model.FeedPost">
        SELECT p.*, u.name AS user_name
        FROM feed_post p
        JOIN `user` u ON p.user_id = u.id
        WHERE p.user_id IN
        <foreach collection="followedUserIds" item="uid" open="(" separator="," close=")">
            #{uid}
        </foreach>
        AND p.created_at &gt; #{since}
        AND (p.visible_until IS NULL OR p.visible_until &gt; NOW())
        AND NOT EXISTS (
            SELECT 1 FROM feed_inbox i WHERE i.user_id = #{userId} AND i.post_id = p.id
        )
        ORDER BY p.created_at DESC
        LIMIT #{size}
    </select>

</mapper>
